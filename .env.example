# Supabase (created in Task 10)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Sentry (created in Task 12)
EXPO_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# PostHog (created in Task 12)
EXPO_PUBLIC_POSTHOG_API_KEY=phc_...
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# MapTiler (geocoding — free tier 100k requests/month)
EXPO_PUBLIC_MAPTILER_API_KEY=

# Google Sign-In (Google Cloud Console → OAuth 2.0 Client IDs)
# Web client ID is used for Supabase token verification.
# iOS client ID + URL scheme come from the iOS OAuth client.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=

# EAS
EAS_PROJECT_ID=
