{
  "name": "this-is-the-journey",
  "version": "0.0.1",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "dev": "expo start --dev-client",
    "dev:tunnel": "expo start --dev-client --tunnel",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "e2e": "maestro test .maestro",
    "prepare": "husky",
    "credits:check": "tsx scripts/check-credits.ts",
    "references:clone": "bash scripts/clone-references.sh",
    "supabase:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > src/core/supabase/types.generated.ts"
  },
  "dependencies": {
    "@expo-google-fonts/fredoka": "^0.4.1",
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo-google-fonts/press-start-2p": "^0.4.1",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@maplibre/maplibre-react-native": "^11.2.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@sentry/react-native": "~7.2.0",
    "@shopify/react-native-skia": "^2.6.4",
    "@stripe/stripe-identity-react-native": "^0.8.0",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-query-persist-client": "^5.59.0",
    "clsx": "^2.1.1",
    "expo": "~54.0.0",
    "expo-apple-authentication": "~8.0.8",
    "expo-application": "~7.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.8",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "i18n-js": "^4.4.0",
    "lucide-react-native": "^1.16.0",
    "nativewind": "^4.1.0",
    "posthog-react-native": "^3.5.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mmkv": "^3.1.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-worklets": "0.5.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@testing-library/react-native": "^12.7.0",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "fs-extra": "~8.1.0",
    "husky": "^9.1.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "react-test-renderer": "19.1.0",
    "tsx": "^4.19.0",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "clsx",
          "@stripe/stripe-identity-react-native"
        ]
      }
    },
    "install": {
      "exclude": [
        "@shopify/react-native-skia"
      ]
    }
  }
}
